# ===========================
# VENARO E-Commerce .gitignore
# ===========================

# --- OS Generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editors ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- PHP ---
*.log
error_log

# --- Environment & Config Secrets ---
.env
.env.*
config.local.php

# --- Node / NPM (for docs tooling) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# --- Composer ---
vendor/
composer.lock

# --- Uploads (user-generated content; not versioned) ---
uploads/products/*
uploads/categories/*
uploads/collections/*
!uploads/products/.gitkeep
!uploads/categories/.gitkeep
!uploads/collections/.gitkeep

# --- Temp / Build artifacts ---
*.tmp
*.bak
*.swp
*.zip
*.rar
*.7z
/tmp/
/temp/

# --- Docs temp files ---
docs/node_modules/
docs/package-lock.json
docs/synopsis_temp/
docs/*.mjs

# --- XAMPP / Apache logs ---
*.pid
*.err
