# ===========================
# VENARO E-Commerce Demo .gitignore
# ===========================

# --- OS Generated ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editors ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- SOURCE CODE HIDING (PREVENT FREE DOWNLOAD) ---
# Ignore all PHP backend logic
**/*.php
# Allow ONLY the main demo index if needed (uncomment if you have a public index.php)
#!index.php

# Ignore sensitive directories
config/
database/
includes/
/tmp/
/temp/

# --- Assets & Presentation ---
# We keep assets/ and docs/ as they show the UI/UX
!assets/
!docs/
!preview.png
!README.md
!LICENSE
!PRD.md

# --- Uploads (Exclude actual content) ---
uploads/*
!uploads/.gitkeep

# --- Node / NPM ---
node_modules/
package-lock.json

# --- XAMPP / Apache logs ---
*.log
error_log
*.pid
*.err
